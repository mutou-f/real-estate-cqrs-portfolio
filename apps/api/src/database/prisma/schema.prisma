generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EventStore {
  id            String   @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  actorUserId   String?
  occurredAt    DateTime @default(now())
}

model ApplicationReadModel {
  applicationId    String   @id
  applicantUserId  String
  propertyName     String
  monthlyRent      Int
  status           ApplicationStatus
  reviewerUserId   String?
  lastEventType    String
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

enum UserRole {
  APPLICANT
  REVIEWER
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}
